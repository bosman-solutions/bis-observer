# .env — COLLECTOR NODE CONFIGURATION
# Copy to .env and fill in before running docker compose up.
# One copy per node. Do NOT commit .env — it has node-specific addressing.

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# IP or hostname of the aggregator node (runs the broker stack).
# Use a stable address — WireGuard IP recommended over DNS.
# Example: 10.10.0.2
AGGREGATOR_HOST=10.0.0.x

# -----------------------------------------------------------------------------
# OPTIONAL — defaults shown, override only if you have port conflicts
# -----------------------------------------------------------------------------

# Node-exporter port on this host.
# Change if something else is already bound to 9100.
#NODE_EXPORTER_PORT=9100

# Aggregator Prometheus remote_write port.
#AGGREGATOR_PROM_PORT=9090

# Aggregator Loki push port.
#AGGREGATOR_LOKI_PORT=3100

# Human-readable name for this node in Grafana.
# Defaults to system hostname — override if your hostname is not meaningful.
#NODE_NAME=node-01

# -----------------------------------------------------------------------------
# KUBERNETES — only needed on k3s/k8s control-plane nodes
# -----------------------------------------------------------------------------

# NodePort that kube-state-metrics is exposed on.
# Leave unset (commented out) on non-k8s nodes — scrape block is skipped.
# Deploy KSM first: helm install kube-state-metrics prometheus-community/kube-state-metrics \
#   --namespace monitoring --create-namespace
# Then: kubectl expose deployment kube-state-metrics --type=NodePort \
#   --port=8080 --name=ksm-nodeport -n monitoring
# Get the assigned port: kubectl get svc ksm-nodeport -n monitoring
#KSM_PORT=32000

# Human-readable cluster name — appears as a label in Grafana.
#CLUSTER_NAME=hybrid-cloud-demo
