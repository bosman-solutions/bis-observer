# environment files contain node-specific addressing — never commit
.env
collector/.env
aggregator/.env

# pull target files are generated by Ansible at deploy time — not source of truth
aggregator/targets/*.yml

# credentialed scrape jobs + their secrets — provisioned only on the aggregator
# that owns a cluster. Keep the .example and the secrets README; ignore the rest.
aggregator/scrape_configs.d/*.yml
aggregator/secrets/*
!aggregator/secrets/README.md

# theseus runtime state — generated dashboards + sidecars.
# The provider config (dashboards.yml) is tracked; all generated .json is not.
aggregator/config/grafana/provisioning/dashboards/*.json

# Python
__pycache__/
*.py[cod]
