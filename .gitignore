# environment files contain node-specific addressing — never commit
.env
collector/.env
aggregator/.env

# pull target files are generated by Ansible at deploy time — not source of truth
aggregator/targets/*.yml

# theseus runtime state — generated at runtime, not source of truth
aggregator/config/grafana/provisioning/dashboards/aggroboard.json
aggregator/config/grafana/provisioning/dashboards/aggroboard_hosts.json
aggregator/config/grafana/provisioning/dashboards/aggrokube.json

# Python
__pycache__/
*.py[cod]
