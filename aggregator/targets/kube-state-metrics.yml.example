# kube-state-metrics.yml — pull target for the kube-state-metrics-pull job.
# Example only. The live file is gitignored and provisioned by Ansible on the
# aggregator that owns the cluster. Absent/empty file => job has no targets.
#
#   targets         <host-ip>:<ksm-nodeport>   (NodePort reported by `make kube`)
#   labels.cluster  cluster name; also the Grafana series label

- targets:
    - "10.0.0.x:30000"
  labels:
    cluster: my-cluster
