# .env — AGGREGATOR NODE CONFIGURATION
# Copy to .env and fill in before running docker compose up.
# Do NOT commit .env to source control.
#
# Grafana credentials are NOT managed here.
# Default login is admin / admin — Grafana will prompt you to change it
# on first login. This is intentional: a plaintext password in an env file
# is a worse attack surface than Grafana's built-in first-login prompt.

# -----------------------------------------------------------------------------
# OPTIONAL — defaults shown, override if needed
# -----------------------------------------------------------------------------

# Ports exposed on this host.
# These must match AGGREGATOR_PROM_PORT and AGGREGATOR_LOKI_PORT
# in each collector node's .env.
#AGGREGATOR_PROM_PORT=9090
#AGGREGATOR_LOKI_PORT=3100
#GRAFANA_PORT=3000

# Prometheus retention period. Format: Xd (days), Xy (years).
#PROM_RETENTION=90d

# Loki retention period. Format: Xh (hours). Default 744h = 31 days.
#LOKI_RETENTION=744h
